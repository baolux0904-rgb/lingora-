{
  "name": "@lingora/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Lingora backend – Node.js + Express REST API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src/**/*.js",
    "migrate:up": "dotenv -e .env -- node-pg-migrate up --migrations-dir migrations",
    "migrate:down": "dotenv -e .env -- node-pg-migrate down --migrations-dir migrations",
    "migrate:down:all": "dotenv -e .env -- node-pg-migrate down --migrations-dir migrations --count 999",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations",
    "migrate:redo": "dotenv -e .env -- node-pg-migrate redo --migrations-dir migrations",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@sentry/node": "^10.43.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "file-type": "^16.5.4",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "music-metadata": "^11.12.3",
    "node-cron": "^4.2.1",
    "node-pg-migrate": "^8.0.4",
    "openai": "^6.31.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "resend": "^6.10.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
